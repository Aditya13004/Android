package com.example.twofragmentsb400080360;

package com.example.twofragmentappb400080360;

import android.os.Bundle;
import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity implements OnButtonPressListener {

    SecondFragment fragmentTwo;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        FirstFragment fragmentOne = new FirstFragment();
        fragmentTwo = new SecondFragment();

        getSupportFragmentManager().beginTransaction()
                .replace(R.id.fragment_one_container, fragmentOne)
                .replace(R.id.fragment_two_container, fragmentTwo)
                .commit();
    }

    @Override
    public void onButtonPressed(String msg) {
        if (fragmentTwo != null) {
            fragmentTwo.onMessageReceived(msg);
        }
    }
}









