package com.example.gridlayoutb400080360;

import android.os.Bundle;
import android.view.View;
import android.widget.Toast;

import androidx.appcompat.app.AppCompatActivity;
import com.google.android.material.card.MaterialCardView;

public class MainActivity extends AppCompatActivity {

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        setupClickListeners();
    }

    private void setupClickListeners() {
        int[] cardIds = {
            R.id.card_ronaldo, R.id.card_messi, R.id.card_neymar,
            R.id.card_benzema, R.id.card_mbappe, R.id.card_haaland,
            R.id.card_ramos, R.id.card_kroos, R.id.card_valverde,
            R.id.card_bruno
        };

        String[] playerNames = {
            getString(R.string.ronaldo), getString(R.string.messi), getString(R.string.neymar),
            getString(R.string.benzema), getString(R.string.mbappe), getString(R.string.haaland),
            getString(R.string.ramos), getString(R.string.kroos), getString(R.string.valverde),
            getString(R.string.bruno)
        };

        for (int i = 0; i < cardIds.length; i++) {
            final String name = playerNames[i];
            MaterialCardView card = findViewById(cardIds[i]);
            if (card != null) {
                card.setOnClickListener(v -> Toast.makeText(MainActivity.this, "Clicked on " + name, Toast.LENGTH_SHORT).show());
            }
        }
    }
}








